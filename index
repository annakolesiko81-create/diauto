  <h4>Почему мы так можем</h4><p>Нам важно, чтобы вы вернулись и рекомендовали нас. Поэтому мы заинтересованы найти реальную причину и сделать ремонт правильно, а не «накрутить» лишнего.</p>
  <h4>Когда диагностика платная</h4><p>Если после диагностики вы решаете ремонтироваться в другом месте — работа диагноста оплачивается по прайсу. Это честно по отношению к мастеру, потративший на вашу машину время.</p>
  <p>Итог: приезжайте без риска — узнаете причину и стоимость заранее.</p>`},
 {c:'ТО',t:'Когда пора на ТО и что в него входит',d:'Простой ориентир по обслуживанию иномарки.',
  body:`<p>Регулярное ТО — самый дешёвый способ избежать дорогого ремонта. Лучше вовремя заменить расходник, чем потом узел целиком.</p>
  <h4>Базовый ориентир</h4><p>Замена масла и фильтров — обычно каждые 10–15 тыс. км или раз в год. Точный интервал зависит от авто и условий: город, пробки, короткие поездки сокращают срок.</p>
  <h4>Что входит в наше ТО</h4><p>Замена масла и фильтров (масляный, воздушный, салонный), проверка и доливка технических жидкостей, осмотр и дефектовка ходовой, считывание ошибок. По итогу — список того, что критично, и что можно спокойно отложить.</p>
  <h4>Расходники в наличии</h4><p>Часто укладываемся в один визит: заехали утром — после обеда машина готова.</p>`}
];

const $=s=>document.querySelector(s),$$=s=>document.querySelectorAll(s);
const icon=p=>`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="${p}"/></svg>`;

$('#svcGrid').innerHTML=SERVICES.map(s=>`<div class="svc"><div class="ic">${icon(s.ic)}</div><h3>${s.t}</h3><p>${s.d}</p></div>`).join('');
$('#priceTicker').innerHTML=[...TICKER,...TICKER].map(p=>`<span class="it">${p[0]} <b>${p[1]}</b></span>`).join('');
$('#priceWrap').innerHTML=PRICES.map(p=>`<div class="price-row ${p[3]?'hl':''}"><div class="name">${p[0]}<b>${p[1]}</b></div>${p[3]?'<div class="p free">0 ₽</div>':`<div class="p"><span>от</span> ${p[2]} ₽</div>`}</div>`).join('');
$('#feedList').innerHTML=FEED.map(f=>`<div class="feed-item"><div class="badge">${f.c}</div><div class="body"><b>${f.t}</b><p>${f.d}</p></div><div class="st"><span class="dot"></span>${f.s}</div></div>`).join('');
$('#revGrid').innerHTML=REVIEWS.map(r=>`<div class="rev"><div class="stars">★★★★★</div><p>${r.t}</p><div class="who"><div class="av">${r.n[0]}</div><div><b>${r.n}</b><span>${r.d} · Яндекс</span></div></div></div>`).join('');
$('#artGrid').innerHTML=ARTICLES.map((a,i)=>`<div class="art" data-i="${i}"><div class="top"></div><div class="in"><span class="cat">${a.c}</span><h3>${a.t}</h3><p>${a.d}</p><span class="more">Читать →</span></div></div>`).join('');
$('#fService').innerHTML='<option>Диагностика</option>'+SERVICES.map(s=>`<option>${s.t}</option>`).join('');

$$('.art').forEach(el=>el.onclick=()=>{const a=ARTICLES[+el.dataset.i];
 $('#modalIn').innerHTML=`<span class="cat">${a.c}</span><h2>${a.t}</h2>${a.body}<div class="modal-cta"><a href="#slots" class="btn btn-amber" id="mBook">Записаться →</a><a href="https://t.me/SeregaKolesovv" target="_blank" rel="noopener" class="btn btn-tg">Написать в Telegram</a></div>`;
 $('#modal').classList.add('show');document.body.style.overflow='hidden';const mb=$('#mBook');if(mb)mb.onclick=closeModal;});
function closeModal(){$('#modal').classList.remove('show');document.body.style.overflow='';}
$('#modalClose').onclick=closeModal;$('#modal').onclick=e=>{if(e.target===$('#modal'))closeModal();};
addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

/* hours 10-19 */
function updStatus(){const h=new Date().getHours(),open=h>=10&&h<19;
 $('#statusDot').classList.toggle('off',!open);$('#statusText').textContent=open?'Открыто':'Закрыто';
 $('#hoursLine').textContent=open?'Сейчас открыто · ежедневно до 19:00':'Сейчас закрыто · ежедневно 10:00–19:00';}
updStatus();setInterval(updStatus,60000);

/* slots */
const HOURS=[10,11,12,13,14,15,16,17,18],DAYS=['Сегодня','Завтра','Послезавтра'],N=HOURS.length;
function seeded(d,h){const b=new Date().getHours();return ((d*7+h*3+b*5)%10)<4;}
function dayDate(o){const d=new Date();d.setDate(d.getDate()+o);return d.toLocaleDateString('ru-RU',{day:'2-digit',month:'2-digit'});}
let curDay=0;
function renderTabs(){$('#dayTabs').innerHTML=DAYS.map((d,i)=>`<button class="day-tab ${i===curDay?'active':''}" data-d="${i}">${d}<b>${dayDate(i)}</b></button>`).join('');
 $$('.day-tab').forEach(b=>b.onclick=()=>{curDay=+b.dataset.d;renderTabs();renderSlots();});}
function freeOn(day){const n=new Date().getHours();let f=0;HOURS.forEach(h=>{if(!((day===0&&h<=n)||seeded(day,h)))f++;});return f;}
function renderSlots(){const n=new Date().getHours();let free=0;
 $('#slotGrid').innerHTML=HOURS.map(h=>{const busy=(curDay===0&&h<=n)||seeded(curDay,h);if(!busy)free++;
  return `<button class="slot ${busy?'busy':'free'}" data-h="${h}" ${busy?'disabled':''}>${String(h).padStart(2,'0')}:00</button>`;}).join('');
 $('#freeCount').textContent=free;const load=Math.round((1-free/N)*100);$('#ring').style.setProperty('--p',load);$('#loadPct').textContent=load+'%';
 $$('.slot.free').forEach(s=>s.onclick=()=>{$$('.slot').forEach(x=>x.classList.remove('sel'));s.classList.add('sel');
  $('#fDay').value=DAYS[curDay];$('#fTime').value=s.dataset.h.padStart(2,'0')+':00';document.getElementById('contacts').scrollIntoView({behavior:'smooth'});});}
$('#freeToday').textContent=freeOn(0);renderTabs();renderSlots();
setInterval(()=>{$('#upd').textContent='только что';renderSlots();$('#freeToday').textContent=freeOn(0);},45000);
$('#fDay').innerHTML=DAYS.map(d=>`<option>${d}</option>`).join('');
$('#fTime').innerHTML=HOURS.map(h=>`<option>${String(h).padStart(2,'0')}:00</option>`).join('');

/* form -> TG/MAX */
const WORKER_URL="ВСТАВЬТЕ_АДРЕС_WORKER";/* напр.: https://diauto-form.xxxx.workers.dev — после деплоя Cloudflare Worker */
$('#submitBtn').onclick=async()=>{const name=$('#fName').value.trim(),phone=$('#fPhone').value.trim();
 if(!name||!phone){[$('#fName'),$('#fPhone')].forEach(f=>{if(!f.value.trim())f.style.borderColor='var(--busy)';});return;}
 const car=$('#fCar').value.trim()||'—',service=$('#fService').value,time=$('#fDay').value+', '+$('#fTime').value;
 const msg=`Заявка с сайта ДеталИномарок\nИмя: ${name}\nТелефон: ${phone}\nАвто: ${car}\nУслуга: ${service}\nЖелаемое время: ${time}`;
 const hp=$('#fWebsite')?$('#fWebsite').value:'';
 const ok=()=>{$('#okSummary').textContent=msg;$('#formBody').style.display='none';$('#formOk').classList.add('show');};
 const fallback=()=>{try{navigator.clipboard&&navigator.clipboard.writeText(msg);}catch(e){}ok();};
 if(WORKER_URL&&WORKER_URL.indexOf('http')===0){const btn=$('#submitBtn'),lbl=btn.textContent;btn.disabled=true;btn.textContent='Отправляем…';
  try{const r=await fetch(WORKER_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,phone,car,service,time,website:hp})});const res=await r.json();if(!res.ok)throw 0;ok();}
  catch(e){fallback();}finally{btn.disabled=false;btn.textContent=lbl;}
 }else{fallback();}
};

/* reveal + bars */
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');
 e.target.querySelectorAll?.('.fill[data-w]').forEach(f=>f.style.width=f.dataset.w+'%');io.unobserve(e.target);}});},{threshold:.15});
$$('.r').forEach(el=>io.observe(el));

const nav=$('#nav');addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>20));
$('#burger').onclick=()=>$('#menu').classList.toggle('open');
$$('#menu a').forEach(a=>a.onclick=()=>$('#menu').classList.remove('open'));
$('#yr').textContent=new Date().getFullYear();
</script>
</body>
