<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ДеталИномарок — автосервис и запчасти в Оренбурге · диагностика бесплатно при ремонте</title>
<meta name="description" content="Автосервис и магазин запчастей для иномарок в Оренбурге. Рейтинг 5.0 на Яндексе. Диагностика бесплатно при ремонте у нас. Двигатель, АКПП, ходовая, тормоза. Запчасти оригинал и аналоги.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0a0b; --bg2:#101012; --surface:#161619; --surface2:#1d1d21;
  --line:rgba(255,255,255,.09); --line2:rgba(255,255,255,.16);
  --ink:#f5f5f6; --muted:#9c9ca6; --muted2:#74747e;
  --amber:#ffc107; --amber-hi:#ffd23f; --amber-deep:#e0a500;
  --grad:linear-gradient(135deg,#ffd23f 0%,#ffb300 100%);
  --ok:#36d07a; --busy:#ff5b5b;
  --r:16px; --rs:10px; --maxw:1240px;
  --shadow:0 24px 60px -20px rgba(0,0,0,.7);
  --disp:'Russo One',sans-serif; --ui:'Manrope',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:var(--ui);line-height:1.55;-webkit-font-smoothing:antialiased;overflow-x:hidden}
h1,h2,h3,h4,.disp{font-family:var(--disp);font-weight:400;line-height:1.05;letter-spacing:.2px}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
.amber{color:var(--amber)}
.eyebrow{font-family:var(--ui);text-transform:uppercase;letter-spacing:3px;font-size:12px;color:var(--amber);font-weight:700;display:inline-flex;align-items:center;gap:10px}
.eyebrow::before{content:"";width:26px;height:2px;background:var(--amber)}
.sec{padding:90px 0;position:relative}
.sec-head{max-width:760px;margin-bottom:46px}
.sec-head h2{font-size:clamp(28px,4.4vw,50px);text-transform:uppercase;margin:14px 0 12px}
.sec-head p{color:var(--muted);font-size:17px;font-family:var(--ui)}
.btn{font-family:var(--ui);font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:14px;display:inline-flex;align-items:center;justify-content:center;gap:9px;padding:15px 26px;border-radius:var(--rs);cursor:pointer;border:none;transition:.25s;white-space:nowrap}
.btn-amber{background:var(--grad);color:#0a0a0b;box-shadow:0 10px 30px -8px rgba(255,193,7,.5)}
.btn-amber:hover{transform:translateY(-2px);box-shadow:0 16px 40px -8px rgba(255,193,7,.65)}
.btn-ghost{background:rgba(255,255,255,.06);color:var(--ink);border:1px solid var(--line2)}
.btn-ghost:hover{background:rgba(255,255,255,.12);border-color:var(--amber)}
.btn-tg{background:#229ed9;color:#fff}.btn-tg:hover{filter:brightness(1.1);transform:translateY(-2px)}
.btn-max{background:#7c4dff;color:#fff}.btn-max:hover{filter:brightness(1.1);transform:translateY(-2px)}

.topbar{background:#000;border-bottom:1px solid var(--line);font-size:13px;color:var(--muted);position:relative;z-index:60}
.topbar .wrap{display:flex;justify-content:space-between;align-items:center;gap:16px;padding:9px 24px;flex-wrap:wrap}
.topbar b{color:var(--ink);font-weight:700}
.dot{width:8px;height:8px;border-radius:50%;background:var(--ok);display:inline-block;box-shadow:0 0 0 0 rgba(54,208,122,.6);animation:pulse 2s infinite}
.dot.off{background:var(--busy);animation:none}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(54,208,122,.55)}70%{box-shadow:0 0 0 9px rgba(54,208,122,0)}100%{box-shadow:0 0 0 0 rgba(54,208,122,0)}}
.topbar .right{display:flex;gap:18px;align-items:center}
.topbar a:hover{color:var(--amber)}

.nav{position:sticky;top:0;z-index:50;backdrop-filter:blur(14px);background:rgba(10,10,11,.72);border-bottom:1px solid transparent;transition:.3s}
.nav.scrolled{background:rgba(10,10,11,.94);border-bottom:1px solid var(--line);box-shadow:0 12px 40px -20px #000}
.nav .wrap{display:flex;align-items:center;gap:24px;padding:14px 24px}
.nav .logo{height:38px;width:auto;max-width:none;flex-shrink:0}
.nav ul{display:flex;gap:22px;list-style:none;margin-left:auto;font-family:var(--ui);text-transform:uppercase;font-size:13px;letter-spacing:1px;font-weight:700}
.nav ul a{color:var(--muted);transition:.2s;position:relative;padding:6px 0}
.nav ul a:hover{color:var(--ink)}
.nav ul a::after{content:"";position:absolute;left:0;bottom:0;height:2px;width:0;background:var(--amber);transition:.25s}
.nav ul a:hover::after{width:100%}
.nav .nav-cta{display:flex;gap:10px;align-items:center}
.burger{display:none;background:none;border:1px solid var(--line2);border-radius:8px;width:44px;height:42px;cursor:pointer;flex-direction:column;gap:5px;align-items:center;justify-content:center}
.burger span{width:20px;height:2px;background:var(--ink);transition:.3s}

.hero{position:relative;min-height:88vh;display:flex;align-items:center;overflow:hidden;border-bottom:1px solid var(--line)}
.hero-bg{position:absolute;inset:0;z-index:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;animation:kb 22s ease-in-out infinite alternate;filter:saturate(1.05)}
@keyframes kb{from{transform:scale(1.05)}to{transform:scale(1.16)}}
.hero-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(100deg,rgba(8,8,9,.96) 0%,rgba(8,8,9,.82) 38%,rgba(8,8,9,.35) 70%,rgba(8,8,9,.55) 100%),radial-gradient(1200px 600px at 18% 30%,rgba(255,193,7,.10),transparent 60%)}
.hero-grid{position:absolute;inset:0;z-index:1;opacity:.4;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(circle at 25% 40%,#000,transparent 75%)}
.hero .wrap{position:relative;z-index:3;padding-top:54px;padding-bottom:54px;width:100%}
.hero-inner{max-width:780px}
.hero h1{font-size:clamp(34px,6vw,66px);text-transform:uppercase;letter-spacing:0}
.hero h1 .ln{display:block;overflow:hidden}
.hero h1 .ln i{display:block;font-style:normal;transform:translateY(110%);animation:rise .9s cubic-bezier(.2,.7,.2,1) forwards}
.hero h1 .ln:nth-child(2) i{animation-delay:.12s}.hero h1 .ln:nth-child(3) i{animation-delay:.24s}
@keyframes rise{to{transform:translateY(0)}}
.reveal-up{opacity:0;transform:translateY(24px);animation:ru .8s ease forwards}
.d1{animation-delay:.45s}.d2{animation-delay:.6s}.d3{animation-delay:.75s}.d4{animation-delay:.9s}
@keyframes ru{to{opacity:1;transform:none}}
.hero-sub{font-size:19px;color:#d6d6da;margin:22px 0 16px;max-width:580px;font-family:var(--ui)}
.hero-sub b{color:#fff}
.hero-free{display:inline-flex;align-items:center;gap:9px;background:rgba(255,193,7,.12);border:1px solid rgba(255,193,7,.35);color:var(--amber-hi);font-weight:700;font-size:14px;padding:9px 15px;border-radius:100px;margin-bottom:26px;font-family:var(--ui)}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:34px}
.hero-facts{display:flex;gap:26px;flex-wrap:wrap}
.hero-fact{display:flex;align-items:center;gap:11px}
.hero-fact .n{font-family:var(--disp);font-size:30px;color:#fff;line-height:1}
.hero-fact small{display:block;color:var(--muted);font-size:13px;max-width:140px;line-height:1.3;font-family:var(--ui)}
.stars{color:var(--amber);letter-spacing:2px;font-size:18px}
.hero-badge{position:absolute;right:6%;top:24%;z-index:3;background:rgba(16,16,18,.7);backdrop-filter:blur(10px);border:1px solid var(--line2);border-radius:var(--r);padding:18px 22px;display:flex;align-items:center;gap:14px;box-shadow:var(--shadow);animation:floaty 6s ease-in-out infinite}
@keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.hero-badge .big{font-family:var(--disp);font-size:40px;color:var(--amber);line-height:1}
.hero-badge small{color:var(--muted);font-size:12px;font-family:var(--ui)}

/* free diagnostics banner */
.freebanner{background:var(--grad);color:#0a0a0b}
.freebanner .wrap{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:20px 24px;flex-wrap:wrap}
.freebanner .txt{display:flex;align-items:center;gap:16px}
.freebanner .gift{flex:0 0 auto;width:54px;height:54px;border-radius:14px;background:#0a0a0b;display:grid;place-items:center;box-shadow:0 8px 20px -8px rgba(0,0,0,.45)}
.freebanner b{font-family:var(--disp);font-size:clamp(18px,2.4vw,26px);text-transform:uppercase;display:block;letter-spacing:.3px}
.freebanner span{font-family:var(--ui);font-weight:600;font-size:14.5px}
.freebanner .btn{background:#0a0a0b;color:#fff}.freebanner .btn:hover{background:#222}

.ticker{background:#000;border-bottom:1px solid var(--line);overflow:hidden;display:flex;align-items:center}
.ticker .lbl{flex:0 0 auto;background:var(--grad);color:#0a0a0b;font-family:var(--ui);font-weight:800;text-transform:uppercase;letter-spacing:1.5px;font-size:12px;padding:14px 20px;z-index:2;white-space:nowrap}
.ticker .track{display:flex;animation:marq 52s linear infinite;white-space:nowrap}
.ticker .track:hover{animation-play-state:paused}
.ticker .it{font-family:var(--ui);font-weight:700;font-size:15px;padding:14px 26px;display:inline-flex;align-items:center;gap:10px;color:var(--ink)}
.ticker .it b{font-family:var(--disp);font-weight:400;color:var(--amber)}
.ticker .it::before{content:"";width:6px;height:6px;background:var(--amber);border-radius:50%;opacity:.5}

/* facts cards */
.facts .tn-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.tn{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:30px 24px;text-align:center;transition:.3s;position:relative;overflow:hidden}
.tn:hover{border-color:var(--line2);transform:translateY(-3px)}
.tn::before{content:"";position:absolute;left:0;top:0;height:3px;width:100%;background:var(--grad);transform:scaleX(0);transform-origin:left;transition:.5s}
.tn:hover::before{transform:scaleX(1)}
.tn .n{font-family:var(--disp);font-size:48px;line-height:1;background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
.tn .l{color:var(--muted);font-size:14px;margin-top:8px;font-family:var(--ui)}
.bars{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:18px}
.bar{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:20px}
.bar .top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:11px}
.bar .top span{font-size:13px;color:var(--muted);font-family:var(--ui)}
.bar .top b{font-family:var(--disp);font-size:20px}
.bar .track{height:7px;background:rgba(255,255,255,.08);border-radius:100px;overflow:hidden}
.bar .fill{height:100%;background:var(--grad);width:0;border-radius:100px;transition:width 1.3s cubic-bezier(.2,.7,.2,1)}

/* slots */
.slots-wrap{display:grid;grid-template-columns:1.15fr .85fr;gap:30px;align-items:start}
.panel{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
.panel-head{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;border-bottom:1px solid var(--line);gap:12px;flex-wrap:wrap}
.panel-head b{font-family:var(--disp);font-size:17px;text-transform:uppercase}
.panel-head .live{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);font-family:var(--ui)}
.day-tabs{display:flex;gap:8px;padding:16px 22px 4px;flex-wrap:wrap}
.day-tab{font-family:var(--ui);text-transform:uppercase;letter-spacing:1px;font-size:12px;font-weight:700;padding:10px 16px;border-radius:100px;border:1px solid var(--line2);background:transparent;color:var(--muted);cursor:pointer;transition:.2s}
.day-tab.active{background:var(--amber);color:#0a0a0b;border-color:var(--amber)}
.day-tab b{display:block;font-size:11px;opacity:.7}
.slot-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;padding:18px 22px 24px}
.slot{font-family:var(--disp);font-size:16px;padding:14px 0;border-radius:var(--rs);text-align:center;border:1px solid var(--line2);background:var(--surface2);cursor:pointer;transition:.18s;position:relative}
.slot:hover{border-color:var(--amber);transform:translateY(-2px)}
.slot.busy{color:var(--muted2);background:transparent;border-style:dashed;cursor:not-allowed;text-decoration:line-through;opacity:.55}
.slot.busy:hover{transform:none;border-color:var(--line2)}
.slot.free::after{content:"";position:absolute;top:7px;right:7px;width:6px;height:6px;border-radius:50%;background:var(--ok)}
.slot.sel{background:var(--grad);color:#0a0a0b;border-color:var(--amber)}
.mini-dash{display:grid;gap:14px}
.md-card{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:22px}
.md-card .k{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-family:var(--ui);font-weight:700}
.md-card .v{font-family:var(--disp);font-size:38px;line-height:1.1;margin-top:6px}
.md-card .v small{font-size:15px;color:var(--muted);font-family:var(--ui)}
.gauge{display:flex;align-items:center;gap:16px}
.ring{--p:96;width:74px;height:74px;border-radius:50%;flex:0 0 74px;background:conic-gradient(var(--amber) calc(var(--p)*1%),rgba(255,255,255,.09) 0);display:grid;place-items:center;position:relative}
.ring::after{content:"";width:56px;height:56px;border-radius:50%;background:var(--surface);position:absolute}
.ring b{position:relative;font-family:var(--disp);font-size:17px}

/* services */
.svc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.svc{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:26px;transition:.3s;position:relative;overflow:hidden}
.svc:hover{transform:translateY(-4px);border-color:var(--line2);background:var(--surface2)}
.svc .ic{width:50px;height:50px;border-radius:12px;background:rgba(255,193,7,.12);display:grid;place-items:center;margin-bottom:16px;color:var(--amber)}
.svc h3{font-size:19px;text-transform:uppercase;margin-bottom:8px}
.svc p{color:var(--muted);font-size:14px;font-family:var(--ui)}
.svc:hover .ic{background:var(--amber);color:#0a0a0b}

/* steps */
.steps{background:var(--bg2)}
.step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;counter-reset:s;margin-top:8px}
.step{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:30px 24px 26px;position:relative}
.step::before{counter-increment:s;content:counter(s);position:absolute;top:-18px;left:24px;width:46px;height:46px;border-radius:12px;background:var(--grad);color:#0a0a0b;font-family:var(--disp);font-size:22px;display:grid;place-items:center}
.step h3{font-size:18px;text-transform:uppercase;margin:18px 0 8px}
.step p{color:var(--muted);font-size:14.5px;font-family:var(--ui)}
.twocard{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}
.tc{display:flex;gap:16px;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:24px}
.tc .ic{flex:0 0 46px;height:46px;border-radius:12px;background:rgba(255,193,7,.12);color:var(--amber);display:grid;place-items:center;font-size:20px}
.tc h4{font-family:var(--disp);font-size:18px;text-transform:uppercase;margin-bottom:5px}
.tc p{color:var(--muted);font-size:14px;font-family:var(--ui)}

/* differentiator */
.diff .inner{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center}
.diff h2{font-size:clamp(28px,4vw,42px);text-transform:uppercase}
.diff p{color:var(--muted);font-size:17px;margin-top:16px;font-family:var(--ui)}
.diff ul{list-style:none;margin-top:22px;display:grid;gap:12px}
.diff li{display:flex;gap:12px;align-items:flex-start;color:#dadade;font-family:var(--ui)}
.diff li .ck{flex:0 0 24px;height:24px;border-radius:7px;background:var(--amber);color:#0a0a0b;display:grid;place-items:center;font-size:13px;font-weight:800}
.diff-card{background:var(--surface);border:1px solid var(--line2);border-radius:var(--r);padding:30px}
.diff-card .cap{font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:18px;font-family:var(--ui)}
.dbar{margin-bottom:18px}
.dbar .t{display:flex;justify-content:space-between;font-size:14px;margin-bottom:7px;font-family:var(--ui)}
.dbar .t b{font-family:var(--disp)}
.dbar .track{height:12px;background:rgba(255,255,255,.08);border-radius:100px;overflow:hidden}
.dbar .fill{height:100%;border-radius:100px;background:var(--grad);width:0;transition:width 1.2s cubic-bezier(.2,.7,.2,1)}
.diff-card .note{font-size:12px;color:var(--muted2);margin-top:6px;font-family:var(--ui)}

/* gallery */
.gal{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:200px;gap:14px}
.gal figure{position:relative;border-radius:var(--r);overflow:hidden;border:1px solid var(--line)}
.gal figure img{width:100%;height:100%;object-fit:cover;transition:.6s}
.gal figure:hover img{transform:scale(1.08)}
.gal figcaption{position:absolute;left:0;right:0;bottom:0;padding:14px 16px;font-family:var(--ui);font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:12px;background:linear-gradient(transparent,rgba(0,0,0,.85));z-index:2}
.gal .big{grid-column:span 2;grid-row:span 2}.gal .tall{grid-row:span 2}

/* feed */
.feed{display:grid;gap:14px}
.feed-item{display:grid;grid-template-columns:auto 1fr auto;gap:18px;align-items:center;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:18px 22px;transition:.3s}
.feed-item:hover{border-color:var(--line2);transform:translateX(4px)}
.feed-item .badge{width:58px;height:54px;border-radius:12px;background:var(--surface2);display:grid;place-items:center;font-family:var(--disp);color:var(--amber);font-size:13px;text-align:center;line-height:1.05;border:1px solid var(--line);padding:0 6px}
.feed-item .body b{font-family:var(--disp);font-size:17px}
.feed-item .body p{color:var(--muted);font-size:14px;font-family:var(--ui)}
.feed-item .st{font-family:var(--ui);font-weight:700;text-transform:uppercase;font-size:12px;letter-spacing:1px;color:var(--ok);display:flex;align-items:center;gap:7px;white-space:nowrap}
.feed-item .st .dot{width:7px;height:7px}

/* prices */
.price-wrap{display:grid;grid-template-columns:1fr;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
.price-row{display:flex;justify-content:space-between;align-items:center;gap:16px;padding:15px 26px;border-bottom:1px solid var(--line);transition:.2s}
.price-row:last-child{border-bottom:none}
.price-row:hover{background:var(--surface2)}
.price-row.hl{background:rgba(255,193,7,.08)}
.price-row .name{font-size:16px;font-family:var(--ui)}
.price-row .name b{display:block;font-family:var(--ui);font-size:11px;color:var(--muted2);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-top:2px}
.price-row .p{font-family:var(--disp);font-size:22px;white-space:nowrap}
.price-row .p span{color:var(--muted);font-size:14px;font-family:var(--ui)}
.price-row .p.free{color:var(--ok)}
.price-note{color:var(--muted2);font-size:13px;margin-top:14px;font-family:var(--ui)}

/* reviews (cards) */
.rev-top{display:flex;gap:24px;align-items:center;flex-wrap:wrap;margin-bottom:30px}
.rev-score{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:22px 30px;text-align:center}
.rev-score .big{font-family:var(--disp);font-size:54px;line-height:.9;background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
.rev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.rev{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:26px;display:flex;flex-direction:column}
.rev .stars{margin-bottom:12px}
.rev p{color:#d6d6da;font-size:15px;flex:1;font-family:var(--ui)}
.rev .who{display:flex;align-items:center;gap:12px;margin-top:18px;padding-top:16px;border-top:1px solid var(--line)}
.rev .av{width:42px;height:42px;border-radius:50%;background:var(--grad);color:#0a0a0b;display:grid;place-items:center;font-family:var(--disp)}
.rev .who b{font-family:var(--disp);font-size:15px}.rev .who span{color:var(--muted);font-size:12px;display:block;font-family:var(--ui)}

/* parts */
.parts{background:var(--bg2)}
.parts .inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
.parts .ph{border-radius:var(--r);overflow:hidden;border:1px solid var(--line)}
.parts h2{font-size:clamp(26px,3.6vw,38px);text-transform:uppercase}
.parts ul{list-style:none;margin:18px 0;display:grid;gap:11px}
.parts li{display:flex;gap:11px;align-items:center;color:var(--muted);font-family:var(--ui)}
.parts li .ck{color:var(--amber);font-weight:800}

/* articles */
.art-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.art{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;transition:.3s;cursor:pointer}
.art:hover{transform:translateY(-4px);border-color:var(--line2)}
.art .top{height:8px;background:var(--grad)}
.art .in{padding:24px}
.art .cat{font-family:var(--ui);text-transform:uppercase;letter-spacing:1px;font-size:12px;color:var(--amber);font-weight:700}
.art h3{font-size:18px;margin:10px 0;line-height:1.2;text-transform:uppercase}
.art p{color:var(--muted);font-size:14.5px;margin-bottom:14px;font-family:var(--ui)}
.art .more{font-family:var(--ui);font-weight:700;text-transform:uppercase;font-size:13px;letter-spacing:1px;color:var(--ink);display:inline-flex;gap:8px;align-items:center}
.art:hover .more{color:var(--amber)}

/* contacts + form */
.contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:30px;align-items:stretch}
.cinfo{display:grid;gap:14px;align-content:start}
.cinfo .row{display:flex;gap:16px;align-items:flex-start;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:20px}
.cinfo .ic{flex:0 0 44px;height:44px;border-radius:11px;background:var(--amber);display:grid;place-items:center;color:#0a0a0b;font-size:20px}
.cinfo .k{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-family:var(--ui);font-weight:700}
.cinfo .val{font-size:17px;font-weight:700;margin-top:2px;font-family:var(--ui)}
.cinfo .val a:hover{color:var(--amber)}
.msg-btns{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px}
.mapbox{border-radius:var(--r);overflow:hidden;border:1px solid var(--line);min-height:300px;position:relative;background:var(--surface)}
.mapbox iframe{width:100%;height:100%;min-height:340px;border:0;filter:grayscale(.2) invert(.92) hue-rotate(180deg) contrast(.9)}
.map-link{position:absolute;left:16px;bottom:16px;z-index:5}
.form{background:linear-gradient(160deg,var(--surface2),var(--surface));border:1px solid var(--line2);border-radius:var(--r);padding:34px;box-shadow:var(--shadow)}
.form h3{font-size:28px;text-transform:uppercase;margin-bottom:6px}
.form .sub{color:var(--muted);margin-bottom:22px;font-size:15px;font-family:var(--ui)}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.field{display:flex;flex-direction:column;gap:6px}.field.full{grid-column:1/-1}
.field label{font-size:12px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);font-family:var(--ui);font-weight:700}
.field input,.field select,.field textarea{background:var(--bg);border:1px solid var(--line2);border-radius:var(--rs);padding:13px 14px;color:var(--ink);font-family:var(--ui);font-size:15px;transition:.2s}
.field textarea{resize:vertical;min-height:60px}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--amber);box-shadow:0 0 0 3px rgba(255,193,7,.15)}
.form .submit{width:100%;justify-content:center;margin-top:18px;font-size:16px;padding:17px}
.form-note{text-align:center;color:var(--muted2);font-size:12.5px;margin-top:14px;font-family:var(--ui)}
.form-ok{display:none;text-align:center;padding:6px 0}.form-ok.show{display:block;animation:ru .5s ease}
.form-ok .ico{width:72px;height:72px;border-radius:50%;background:rgba(54,208,122,.15);color:var(--ok);display:grid;place-items:center;margin:0 auto 16px;font-size:36px}
.form-ok .sm{background:var(--bg);border:1px solid var(--line);border-radius:var(--rs);padding:14px;margin:16px 0;font-size:14px;color:var(--muted);font-family:var(--ui);text-align:left;white-space:pre-line}
.form-ok .sm b{color:var(--ink)}
.ok-btns{display:grid;gap:10px}

footer{background:#000;border-top:1px solid var(--line);padding:56px 0 28px}
.foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:36px}
.foot-logo{height:40px;width:auto;max-width:none;margin-bottom:16px}
footer p{color:var(--muted);font-size:14px;font-family:var(--ui)}
.foot-col h5{font-family:var(--disp);text-transform:uppercase;letter-spacing:.5px;font-size:14px;margin-bottom:14px;color:var(--ink)}
.foot-col a{display:block;color:var(--muted);font-size:14px;padding:5px 0;transition:.2s;font-family:var(--ui)}
.foot-col a:hover{color:var(--amber)}
.foot-bottom{border-top:1px solid var(--line);margin-top:36px;padding-top:22px;display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;color:var(--muted2);font-size:13px;font-family:var(--ui)}
.soc{display:flex;gap:10px}
.soc a{width:40px;height:40px;border-radius:10px;border:1px solid var(--line2);display:grid;place-items:center;color:var(--muted);transition:.2s;font-family:var(--disp);font-size:13px}
.soc a:hover{background:var(--amber);color:#0a0a0b;border-color:var(--amber)}

.mcta{display:none;position:fixed;bottom:0;left:0;right:0;z-index:80;background:var(--bg2);border-top:1px solid var(--line);padding:10px 14px;gap:10px;box-shadow:0 -8px 30px -18px #000}
.mcta .btn{flex:1}

.modal{position:fixed;inset:0;z-index:200;display:none;align-items:flex-start;justify-content:center;padding:40px 20px;overflow:auto;background:rgba(5,5,6,.8);backdrop-filter:blur(6px)}
.modal.show{display:flex}
.modal-box{background:var(--bg2);border:1px solid var(--line2);border-radius:var(--r);max-width:760px;width:100%;overflow:hidden;animation:ru .4s ease;position:relative}
.modal-hd{height:8px;background:var(--grad)}
.modal-in{padding:38px}
.modal-in .cat{font-family:var(--ui);text-transform:uppercase;letter-spacing:1px;font-size:12px;color:var(--amber);font-weight:700}
.modal-in h2{font-size:28px;text-transform:uppercase;margin:10px 0 16px;line-height:1.1}
.modal-in p{font-family:var(--ui);color:#d3d3d8;font-size:16px;line-height:1.75;margin-bottom:13px}
.modal-in h4{font-family:var(--disp);font-size:17px;text-transform:uppercase;margin:20px 0 7px;color:var(--ink)}
.modal-close{position:absolute;top:22px;right:24px;width:44px;height:44px;border-radius:50%;border:1px solid var(--line2);background:rgba(0,0,0,.4);color:#fff;font-size:20px;cursor:pointer;z-index:5}
.modal-cta{margin-top:22px;display:flex;gap:10px;flex-wrap:wrap}

.r{opacity:0;transform:translateY(28px);transition:.8s cubic-bezier(.2,.7,.2,1)}.r.in{opacity:1;transform:none}

@media(max-width:1040px){.svc-grid{grid-template-columns:repeat(2,1fr)}}
